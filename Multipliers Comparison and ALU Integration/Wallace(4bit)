    threeleveladder8 add21(s11, c11_shift, p3, s21, c21);

    assign c21_shift = c21 << 1;   // ✅ FIX

    // Final addition
    wire cout;
    eight_bit_Recursive_Carry_Adder cla(product, cout, s21, c21_shift);

